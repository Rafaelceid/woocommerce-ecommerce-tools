# Ifiale environment variables — copy to .env and fill in real values
# NEVER commit .env to git

# WooCommerce REST API credentials (from WooCommerce > Settings > Advanced > REST API)
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudinary (for csv_cloudinary_normalizer.py — server-side bulk upload)
# Never put these in client-side code. Use unsigned preset for browser uploads.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Cloudinary unsigned upload preset (for browser-side ifiale-image-studio.html)
# Create at: Cloudinary > Settings > Upload > Upload presets > Add upload preset
# Set Signing Mode = Unsigned. Safe to expose in HTML.
CLOUDINARY_UPLOAD_PRESET=ifiale_unsigned

# ImgBB (alternative CDN for batch CSV normalizer)
IMGBB_API_KEY=your_imgbb_key

# Brandfetch API (for fetch_brand_logos.py)
BRANDFETCH_API_KEY=your_brandfetch_key
